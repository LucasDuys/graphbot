# GraphBot Environment Configuration
# Copy this file to .env.local and fill in your values.
#
# Required keys are marked [REQUIRED]; optional keys are marked [OPTIONAL].
# At least ONE provider API key must be set for GraphBot to function.

# ---------------------------------------------------------------------------
# LLM Provider API Keys
# ---------------------------------------------------------------------------

# [REQUIRED] OpenRouter -- primary provider for multi-model routing.
# Get your key at https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-...

# [OPTIONAL] Google AI Studio -- Gemini 2.5 Pro free tier (~5 RPM).
# Get your key at https://aistudio.google.com/apikey
GOOGLE_API_KEY=

# [OPTIONAL] Groq -- fast inference, free tier (~30 RPM).
# Get your key at https://console.groq.com/keys
GROQ_API_KEY=

# ---------------------------------------------------------------------------
# Messaging Channels
# ---------------------------------------------------------------------------

# [OPTIONAL] Telegram bot integration.
# Create a bot via @BotFather and paste the token here.
TELEGRAM_BOT_TOKEN=

# [OPTIONAL] WhatsApp bridge connection (Node.js Baileys bridge).
# Default: ws://localhost:3001
WHATSAPP_BRIDGE_URL=ws://localhost:3001

# [OPTIONAL] Auth token for the WhatsApp bridge (if bridge requires auth).
WHATSAPP_BRIDGE_TOKEN=

# ---------------------------------------------------------------------------
# Observability -- LangSmith Tracing
# ---------------------------------------------------------------------------

# [OPTIONAL] LangSmith/LangChain API key for tracing.
# If not set, tracing is silently disabled.
# Get your key at https://smith.langchain.com/settings
LANGCHAIN_API_KEY=

# [OPTIONAL] LangSmith project name (default: graphbot).
LANGCHAIN_PROJECT=graphbot

# [OPTIONAL] Enable LangChain tracing (default: true when API key is set).
LANGCHAIN_TRACING_V2=true

# [OPTIONAL] LangSmith tracing toggle (default: true when API key is set).
LANGSMITH_TRACING=true

# [OPTIONAL] LangSmith project name mirror (default: graphbot).
LANGSMITH_PROJECT=graphbot

# [OPTIONAL] LangSmith API endpoint (default: EU endpoint).
LANGSMITH_ENDPOINT=https://eu.api.smith.langchain.com

# [OPTIONAL] LangChain API endpoint (default: EU endpoint).
LANGCHAIN_ENDPOINT=https://eu.api.smith.langchain.com

# ---------------------------------------------------------------------------
# Shell Sandbox -- Command Allowlist / Blocklist
# ---------------------------------------------------------------------------

# [OPTIONAL] Comma-separated list of allowed shell commands.
# When set, ONLY these commands can be executed by ShellTool.
# If empty or unset, all commands are allowed (subject to blocklist and
# built-in dangerous pattern checks).
# Example: SHELL_ALLOWLIST=echo,ls,python,git,cat,grep
SHELL_ALLOWLIST=

# [OPTIONAL] Comma-separated list of blocked shell commands.
# These commands are blocked on top of the built-in dangerous patterns.
# Blocklist is checked before allowlist (blocklist takes precedence).
# Example: SHELL_BLOCKLIST=curl,wget,nc,ncat,ssh,scp
SHELL_BLOCKLIST=

# ---------------------------------------------------------------------------
# Browser Sandbox -- Domain Allowlist / Blocklist / Form Control
# ---------------------------------------------------------------------------

# [OPTIONAL] Comma-separated list of allowed domains for browser navigation.
# When set, ONLY these domains (and their subdomains) can be visited.
# If empty or unset, all domains are permitted (subject to blocklist).
# Example: BROWSER_ALLOWLIST=example.com,docs.python.org,github.com
BROWSER_ALLOWLIST=

# [OPTIONAL] Comma-separated list of blocked domains for browser navigation.
# These domains (and their subdomains) are always rejected.
# Blocklist is checked before allowlist (blocklist takes precedence).
# Example: BROWSER_BLOCKLIST=evil.com,malware.org
BROWSER_BLOCKLIST=

# [OPTIONAL] Allow browser form submissions (fill action).
# Set to "true" to enable. Forms are blocked by default for safety.
# Example: BROWSER_ALLOW_FORMS=true
BROWSER_ALLOW_FORMS=
